library(phytools)
# Load individual trees
tree1 <- read.tree("1.txt")
tree2 <- read.tree("2.txt")
tree3 <- read.tree("3.txt")
# Combine them into a list
my_trees <- c(tree1, tree2, tree3)
# Generate the combined tree
combined_tree <- superTree(my_trees, method="mincut")
combined_tree <- phytools::superTree(my_trees, method="mincut")
remove.packages("phytools")
install.packages("phytools", dependencies = TRUE)
library(phytools)
# Load individual trees
tree1 <- read.tree("1.txt")
tree2 <- read.tree("2.txt")
tree3 <- read.tree("3.txt")
# Combine them into a list
my_trees <- c(tree1, tree2, tree3)
# Generate the combined tree
combined_tree <- superTree(my_trees, method="mincut")
combined_tree <- phytools::superTree(my_trees, method="mincut")
# 1. Install and load phangorn if you haven't already
if (!require("phangorn")) install.packages("phangorn")
library(phangorn)
# Convert your trees with different taxa into a single matrix
# This handles the overlapping/missing sequences automatically
mrp_data <- mrpMatrix(my_trees)
# Convert your trees with different taxa into a single matrix
# This handles the overlapping/missing sequences automatically
mrp_data <- mrp(my_trees)
# 1. Manually create the MRP Matrix
# This function converts your trees into a binary data object
mrp_matrix <- propPart(my_trees)
library(ape)
# 1. Manually create the MRP Matrix
# This function converts your trees into a binary data object
mrp_matrix <- propPart(my_trees)
# 1. Manually create the MRP Matrix
# This function converts your trees into a binary data object
mrp_matrix <- prop.part(my_trees)
my_trees <- lapply(my_trees, function(x) {
x$edge.length <- NULL # MRP uses topology only
return(x)
})
class(my_trees) <- "multiPhylo"
class(my_trees)
# 2. This is the magic step for different tip labels:
# It creates a binary matrix where '?' is used for missing taxa
message("Creating matrix from overlapping taxa...")
mrp_matrix <- phangorn:::mrpData(my_trees)
mrp_matrix <- phangorn::mrpData(my_trees)
all_taxa <- unique(unlist(lapply(my_trees, function(x) x$tip.label)))
make_mrp_part <- function(tr, all_taxa) {
# Get the splits (partitions) for this specific tree
bp <- prop.part(tr)
# Convert splits to a matrix (Rows = Taxa, Cols = Splits)
mat <- matrix("?", length(all_taxa), length(bp),
dimnames = list(all_taxa, NULL))
for(i in 1:length(bp)) {
present <- tr$tip.label[bp[[i]]]
absent <- setdiff(tr$tip.label, present)
mat[present, i] <- "1"
mat[absent, i] <- "0"
}
return(mat)
}
# 3. Combine all trees into one large Supermatrix
full_matrix <- do.call(cbind, lapply(my_trees, make_mrp_part, all_taxa = all_taxa))
# 4. Convert to a format R can use for tree building
mrp_data <- as.phyDat(full_matrix, type = "USER", levels = c("0", "1"))
# 3. Find the "Best" combined tree using a Parsimony Ratchet search
# 'trace = 0' just keeps the console clean
combined_tree <- pratchet(as.phyDat(mrp_data), trace = 0)
# 4. The result is often a set of trees; pick the first one or create a consensus
final_tree <- root(combined_tree[[1]], outgroup = "YOUR_OUTGROUP_NAME")
# 3. Combine all trees into one large Supermatrix
full_matrix <- do.call(cbind, lapply(my_trees, make_mrp_part, all_taxa = all_taxa))
# 4. Convert to a format R can use for tree building
mrp_data <- as.phyDat(full_matrix, type = "USER", levels = c("0", "1"))
# 5. Find the best Supertree (The Parsimony Ratchet)
combined_results <- pratchet(mrp_data, trace = 0)
# 6. Final Consensus and Plot
final_tree <- consensus(combined_results, p = 0.5)
plot(final_tree, main="Manual MRP Supertree")
#7 Saving Tree
write.tree(final_tree, file = "my_combined_supertree.tre")
# Install and load phangorn
if (!require("phangorn")) install.packages("phangorn")
library(phangorn)
library(ape)
# Load individual trees
tree1 <- read.tree("1.txt")
tree2 <- read.tree("2.txt")
tree3 <- read.tree("3.txt")
# Combine them into a list
my_trees <- c(tree1, tree2, tree3)
# Get a master list of every unique taxon across all trees
all_taxa <- unique(unlist(lapply(my_trees, function(x) x$tip.label)))
# Function to convert each tree into a binary matrix with missing data (?)
# This is the manual version of what 'mrpData' does
make_mrp_part <- function(tr, all_taxa) {
# Get the splits (partitions) for this specific tree
bp <- prop.part(tr)
# Convert splits to a matrix (Rows = Taxa, Cols = Splits)
mat <- matrix("?", length(all_taxa), length(bp),
dimnames = list(all_taxa, NULL))
for(i in 1:length(bp)) {
present <- tr$tip.label[bp[[i]]]
absent <- setdiff(tr$tip.label, present)
mat[present, i] <- "1"
mat[absent, i] <- "0"
}
return(mat)
}
# Combine all trees into one large Supermatrix
full_matrix <- do.call(cbind, lapply(my_trees, make_mrp_part, all_taxa = all_taxa))
# Convert to a format R can use for tree building
mrp_data <- as.phyDat(full_matrix, type = "USER", levels = c("0", "1"))
# Find the best Supertree (The Parsimony Ratchet)
combined_results <- pratchet(mrp_data, trace = 0)
# Final Consensus and Plot
final_tree <- consensus(combined_results, p = 0.5)
plot(final_tree, main="Manual MRP Supertree")
# Saving Tree
write.tree(final_tree, file = "my_combined_supertree.tre")
# Viewing Tree
#Use FigTree to visualize the resulting .tre file
#Root the tree inside of FigTree
